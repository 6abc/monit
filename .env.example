# Copy this file to .env and fill in real values:
#   cp .env.example .env
#   chmod 600 .env
#
# .env is used by docker-compose.yml only (Grafana env vars).
# Alertmanager credentials are separate - see alertmanager/alertmanager.yml.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
GRAFANA_ROOT_URL=http://192.168.1.203:3000
